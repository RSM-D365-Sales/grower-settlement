{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "namePrefix": { "value": "growerset" },
    "corsOrigins": {
      "value": [
        "http://localhost:5174",
        "https://<org>.github.io"
      ]
    },
    "entraTenantId": { "value": "" },
    "apiClientId": { "value": "" },
    "sqlAdminLogin": { "value": "groweradmin" },
    "sqlAdminPassword": {
      "reference": {
        "keyVault": { "id": "<key-vault-resource-id>" },
        "secretName": "sql-admin-password"
      }
    }
  }
}
