# Copy to .env.local (or set as GitHub Actions vars for the Pages deploy).
# AUTH: "entra" for real sign-in, "mock" for local dev without a tenant.
VITE_AUTH_MODE=entra
VITE_API_BASE_URL=https://<your-function-app>.azurewebsites.net/api
VITE_ENTRA_CLIENT_ID=<SPA app registration client id>
VITE_ENTRA_TENANT_ID=<tenant id>
# Scope exposed by the API app registration, e.g. api://<api-client-id>/access_as_user
VITE_API_SCOPE=api://<api-client-id>/access_as_user
